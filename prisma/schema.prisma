generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum AuthTokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model User {
  id                    String                 @id @default(uuid()) @db.Uuid
  firstName             String
  lastName              String
  email                 String                 @unique
  passwordHash          String?
  avatarUrl             String?
  emailVerifiedAt       DateTime?
  status                UserStatus             @default(ACTIVE)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  collections           Collection[]           @relation("CollectionCreator")
  addedToCollections    CollectionItem[]       @relation("CollectionItemAdder")
  createdDocuments      Document[]             @relation("DocumentCreator")
  docCollaboratorsAdded DocumentCollaborator[] @relation("DocCollaboratorsAdder")
  docCollaborator       DocumentCollaborator[] @relation("DocCollaboratorsUser")
  uploads               File[]                 @relation("FileUploader")
  globalPrefs           GlobalUserPrefs?
  sentMessages          Message[]              @relation("MessageSender")
  messageMentions       MessageMention[]
  messageReactions      MessageReaction[]
  oauthIdentities       OauthIdentity[]
  authTokens            AuthToken[]
  createdProjects       Project[]              @relation("ProjectCreator")
  projectMembers        ProjectMember[]
  projectSettings       ProjectSettings[]
  createdMeetings       Meeting[]              @relation("MeetingCreator")
  sessions              Session[]
  createdTaskBoards     TaskBoard[]            @relation("TaskBoardCreator")
  addedTaskBoardItems   TaskBoardItem[]        @relation("TaskBoardItemAdder")
  createdThreads        Thread[]               @relation("ThreadCreator")
  threadMembers         ThreadMember[]
  threadPrefs           ThreadUserPrefs[]
  notifications         Notification[]         @relation("NotificationUser")
  notificationsFrom     Notification[]         @relation("NotificationActor")
}

model OauthIdentity {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  provider       String
  providerUserId String
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // NEW (all optional → backwards compatible)
  accessToken    String?
  refreshToken   String?
  scope          String?
  tokenType      String?
  expiresAt      DateTime?

  @@unique([provider, providerUserId])
  @@index([userId])
}

model AuthToken {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @db.Uuid
  purpose    AuthTokenPurpose
  tokenHash  String // store hash of code/token (bcrypt/argon)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([expiresAt])
}

model Session {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  createdAt DateTime  @default(now())
  expiresAt DateTime
  ip        String?
  userAgent String?
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id                  String               @id @default(uuid()) @db.Uuid
  name                String
  slug                String?              @unique
  createdById         String               @db.Uuid
  visibility          ProjectVisibility    @default(PRIVATE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  discussion          Discussion?
  documents           Document[]
  embeds              Embed[]
  files               File[]
  invites             Invite[]
  createdBy           User                 @relation("ProjectCreator", fields: [createdById], references: [id])
  members             ProjectMember[]
  settings            ProjectSettings[]
  propertyDefinitions PropertyDefinition[]
  taskBoards          TaskBoard[]
  meetings            Meeting[]
  notifications       Notification[]

  @@index([createdById])
}

model ProjectMember {
  projectId String      @db.Uuid
  userId    String      @db.Uuid
  role      ProjectRole @default(MEMBER)
  joinedAt  DateTime    @default(now())
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
}

model Invite {
  id         String      @id @default(uuid()) @db.Uuid
  projectId  String      @db.Uuid
  email      String
  role       ProjectRole
  token      String      @unique
  expiresAt  DateTime?
  acceptedAt DateTime?
  createdAt  DateTime    @default(now())
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
  @@index([projectId])
  @@index([email])
}

model ProjectSettings {
  projectId            String     @db.Uuid
  userId               String     @db.Uuid
  notificationsEnabled Boolean    @default(true)
  defaultThreadMode    ThreadMode @default(ALL)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  project              Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model GlobalUserPrefs {
  userId               String     @id @db.Uuid
  theme                String     @default("system")
  locale               String?    @default("en-US")
  timezone             String?    @default("UTC")
  notificationsEnabled Boolean    @default(true)
  defaultThreadMode    ThreadMode @default(ALL)
  emailOptIn           Boolean    @default(true)
  dndStart             String?
  dndEnd               String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id              String                  @id @default(uuid()) @db.Uuid
  projectId       String                  @db.Uuid
  title           String
  content         Json
  parentId        String?                 @db.Uuid
  isArchived      Boolean                 @default(false)
  createdById     String                  @db.Uuid
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  description     String?
  collections     Collection[]
  collectionItems CollectionItem[]
  createdBy       User                    @relation("DocumentCreator", fields: [createdById], references: [id])
  parent          Document?               @relation("DocChildren", fields: [parentId], references: [id])
  children        Document[]              @relation("DocChildren")
  project         Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  collaborators   DocumentCollaborator[]
  documentFiles   DocumentFile[]
  properties      DocumentProperty[]
  propertyValues  DocumentPropertyValue[]
  embeds          Embed[]
  boardHostOf     TaskBoard[]             @relation("BoardHost")
  taskBoardItems  TaskBoardItem[]

  @@index([projectId])
  @@index([parentId])
  @@index([createdById])
  @@index([projectId, createdAt])
}

model DocumentCollaborator {
  documentId String              @db.Uuid
  userId     String              @db.Uuid
  role       DocCollaboratorRole @default(VIEWER)
  addedById  String              @db.Uuid
  addedAt    DateTime            @default(now())
  addedBy    User                @relation("DocCollaboratorsAdder", fields: [addedById], references: [id])
  document   Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User                @relation("DocCollaboratorsUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([documentId, userId])
  @@index([userId])
  @@index([addedById])
}

model File {
  id                 String              @id @default(uuid()) @db.Uuid
  projectId          String              @db.Uuid
  uploaderId         String              @db.Uuid
  filename           String
  mime               String
  size               Int
  storageKey         String
  createdAt          DateTime            @default(now())
  documentFiles      DocumentFile[]
  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader           User                @relation("FileUploader", fields: [uploaderId], references: [id])
  messageAttachments MessageAttachment[]

  @@index([projectId])
  @@index([uploaderId])
}

model DocumentFile {
  documentId String   @db.Uuid
  fileId     String   @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  file       File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([documentId, fileId])
}

model Embed {
  id         String    @id @default(uuid()) @db.Uuid
  projectId  String    @db.Uuid
  documentId String?   @db.Uuid
  kind       String
  url        String
  meta       Json?
  createdAt  DateTime  @default(now())
  document   Document? @relation(fields: [documentId], references: [id])
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([documentId])
}

model PropertyDefinition {
  id               String                   @id @default(uuid()) @db.Uuid
  projectId        String                   @db.Uuid
  name             String
  type             String
  createdAt        DateTime                 @default(now())
  usedByDocs       DocumentProperty[]
  propertyValues   DocumentPropertyValue[]
  project          Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  options          PropertyOption[]
  assigneeBindings TaskBoardBindings[]      @relation("TB_AssigneeProp")
  dueBindings      TaskBoardBindings[]      @relation("TB_DueProp")
  statusBindings   TaskBoardBindings[]      @relation("TB_StatusProp")
  viewVisibility   ViewPropertyVisibility[]

  @@index([projectId])
}

model PropertyOption {
  id                     String                  @id @default(uuid()) @db.Uuid
  propertyId             String                  @db.Uuid
  value                  String
  color                  String?
  position               Int?
  documentPropertyValues DocumentPropertyValue[] @relation("DocumentPropertyValue_option")
  property               PropertyDefinition      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  columns                TaskBoardColumn[]

  @@unique([propertyId, value])
  @@index([propertyId])
}

model DocumentProperty {
  documentId String             @db.Uuid
  propertyId String             @db.Uuid
  document   Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  property   PropertyDefinition @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([documentId, propertyId])
}

model DocumentPropertyValue {
  id          String             @id @default(uuid()) @db.Uuid
  documentId  String             @db.Uuid
  propertyId  String             @db.Uuid
  valueString String?
  valueNumber Float?
  valueBool   Boolean?
  valueDate   DateTime?
  valueJson   Json?
  optionId    String?            @db.Uuid
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  document    Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  option      PropertyOption?    @relation("DocumentPropertyValue_option", fields: [optionId], references: [id])
  property    PropertyDefinition @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([documentId, propertyId])
  @@index([documentId])
  @@index([propertyId])
  @@index([optionId])
}

model Collection {
  id                 String                   @id @default(uuid()) @db.Uuid
  documentId         String                   @db.Uuid
  name               String
  type               String
  createdById        String                   @db.Uuid
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  createdBy          User                     @relation("CollectionCreator", fields: [createdById], references: [id])
  document           Document                 @relation(fields: [documentId], references: [id], onDelete: Cascade)
  items              CollectionItem[]
  propertyVisibility ViewPropertyVisibility[]

  @@index([documentId])
  @@index([createdById])
}

model CollectionItem {
  collectionId String     @db.Uuid
  documentId   String     @db.Uuid
  position     Int?
  addedById    String     @db.Uuid
  createdAt    DateTime   @default(now())
  addedBy      User       @relation("CollectionItemAdder", fields: [addedById], references: [id])
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  document     Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([collectionId, documentId])
  @@index([documentId])
  @@index([addedById])
}

model ViewPropertyVisibility {
  id           String             @id @default(uuid()) @db.Uuid
  collectionId String             @db.Uuid
  propertyId   String             @db.Uuid
  visible      Boolean            @default(true)
  collection   Collection         @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  property     PropertyDefinition @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([collectionId])
  @@index([propertyId])
}

model TaskBoard {
  id             String             @id @default(uuid()) @db.Uuid
  projectId      String             @db.Uuid
  name           String
  hostDocumentId String?            @db.Uuid
  createdById    String             @db.Uuid
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      User               @relation("TaskBoardCreator", fields: [createdById], references: [id])
  hostDocument   Document?          @relation("BoardHost", fields: [hostDocumentId], references: [id])
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bindings       TaskBoardBindings?
  columns        TaskBoardColumn[]
  items          TaskBoardItem[]

  @@index([projectId])
  @@index([hostDocumentId])
  @@index([createdById])
}

model TaskBoardBindings {
  taskBoardId        String             @id @db.Uuid
  statusPropertyId   String             @db.Uuid
  assigneePropertyId String             @db.Uuid
  duePropertyId      String             @db.Uuid
  assigneeProperty   PropertyDefinition @relation("TB_AssigneeProp", fields: [assigneePropertyId], references: [id])
  dueProperty        PropertyDefinition @relation("TB_DueProp", fields: [duePropertyId], references: [id])
  statusProperty     PropertyDefinition @relation("TB_StatusProp", fields: [statusPropertyId], references: [id])
  board              TaskBoard          @relation(fields: [taskBoardId], references: [id], onDelete: Cascade)

  @@index([statusPropertyId])
  @@index([assigneePropertyId])
  @@index([duePropertyId])
}

model TaskBoardColumn {
  id          String          @id @default(uuid()) @db.Uuid
  taskBoardId String          @db.Uuid
  optionId    String          @db.Uuid
  label       String
  position    Int?
  option      PropertyOption  @relation(fields: [optionId], references: [id])
  board       TaskBoard       @relation(fields: [taskBoardId], references: [id], onDelete: Cascade)
  items       TaskBoardItem[]

  @@index([taskBoardId])
  @@index([optionId])
}

model TaskBoardItem {
  taskBoardId String          @db.Uuid
  documentId  String          @db.Uuid
  columnId    String          @db.Uuid
  position    Int?
  addedById   String          @db.Uuid
  addedAt     DateTime        @default(now())
  addedBy     User            @relation("TaskBoardItemAdder", fields: [addedById], references: [id])
  column      TaskBoardColumn @relation(fields: [columnId], references: [id])
  document    Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  board       TaskBoard       @relation(fields: [taskBoardId], references: [id], onDelete: Cascade)

  @@id([taskBoardId, documentId])
  @@index([columnId])
  @@index([addedById])
}

model Discussion {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @unique @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  threads   Thread[]
}

model Thread {
  id            String            @id @default(uuid()) @db.Uuid
  discussionId  String            @db.Uuid
  topic         String
  description   String?
  createdById   String            @db.Uuid
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  messages      Message[]
  createdBy     User              @relation("ThreadCreator", fields: [createdById], references: [id])
  discussion    Discussion        @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  members       ThreadMember[]
  prefs         ThreadUserPrefs[]
  notifications Notification[]

  @@index([discussionId])
  @@index([createdById])
}

model ThreadMember {
  threadId String   @db.Uuid
  userId   String   @db.Uuid
  role     String?
  joinedAt DateTime @default(now())
  thread   Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
  @@index([userId])
}

model ThreadUserPrefs {
  threadId   String     @db.Uuid
  userId     String     @db.Uuid
  mode       ThreadMode @default(ALL)
  isMuted    Boolean    @default(false)
  lastReadAt DateTime?
  updatedAt  DateTime   @updatedAt
  thread     Thread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
}

model Message {
  id        String    @id @default(uuid()) @db.Uuid
  threadId  String    @db.Uuid
  senderId  String    @db.Uuid
  body      String
  bodyJson  Json?
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  deletedAt DateTime?
  replyToId String?   @db.Uuid
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReplies")

  sender        User                @relation("MessageSender", fields: [senderId], references: [id])
  thread        Thread              @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments   MessageAttachment[]
  mentions      MessageMention[]
  reactions     MessageReaction[]
  notifications Notification[]

  @@index([threadId])
  @@index([senderId])
  @@index([threadId, createdAt])
}

model MessageMention {
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
}

model MessageReaction {
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId, emoji])
}

model MessageAttachment {
  messageId String  @db.Uuid
  fileId    String  @db.Uuid
  file      File    @relation(fields: [fileId], references: [id], onDelete: Cascade)
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([messageId, fileId])
}

model Meeting {
  id                  String        @id @default(uuid()) @db.Uuid
  projectId           String        @db.Uuid
  createdById         String        @db.Uuid
  title               String
  joinCode            String        @unique // used in /meet/[joinCode]
  livekitRoomName     String        @unique // room name for LiveKit
  status              MeetingStatus @default(SCHEDULED)
  hasRecording        Boolean       @default(false)
  hasTranscript       Boolean       @default(false)
  transcript          String? // full static transcript text
  transcriptCreatedAt DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // relations
  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy  User               @relation("MeetingCreator", fields: [createdById], references: [id])
  recordings MeetingRecording[]
  segments   MeetingSegment[] // diarized chunks: speaker + timestamps
  speakers   MeetingSpeaker[]

  @@index([projectId])
  @@index([createdById])
  @@index([projectId, createdAt])
}

model MeetingSpeaker {
  id           String @id @default(uuid()) @db.Uuid
  meetingId    String @db.Uuid
  speakerIndex Int
  label        String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, speakerIndex])
  @@index([meetingId])
}

model MeetingRecording {
  id        String                 @id @default(uuid()) @db.Uuid
  meetingId String                 @db.Uuid
  egressId  String // LiveKit egress job ID
  s3Key     String // e.g. "recordings/<meetingId>-<timestamp>.mp4"
  status    MeetingRecordingStatus @default(IN_PROGRESS)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([egressId])
}

model MeetingSegment {
  id           String @id @default(uuid()) @db.Uuid
  meetingId    String @db.Uuid
  startMs      Int // start time in milliseconds
  endMs        Int // end time in milliseconds
  speakerIndex Int // 0, 1, 2, ... → you'll render as "Speaker {speakerIndex + 1}"
  text         String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([speakerIndex])
}

enum NotificationType {
  MENTION
}

model Notification {
  id String @id @default(uuid()) @db.Uuid

  // recipient
  userId String @db.Uuid

  // who triggered it (sender)
  actorId String? @db.Uuid

  type NotificationType

  // context (so you can link without guessing)
  projectId String @db.Uuid
  threadId  String @db.Uuid
  messageId String @db.Uuid

  title       String
  bodyPreview String?
  url         String?

  createdAt DateTime  @default(now())
  readAt    DateTime?

  user    User    @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  thread  Thread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // prevents duplicates if the same message creation is retried
  @@unique([userId, type, messageId])
  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum ProjectVisibility {
  PRIVATE
  LINK
  ORG
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
}

enum DocCollaboratorRole {
  VIEWER
  COMMENTER
  EDITOR
}

enum ThreadMode {
  ALL
  MENTIONS
  NONE
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum MeetingRecordingStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}
